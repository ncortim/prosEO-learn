server:
  http_listen_port: 9080
  grpc_listen_port: 0

positions:
  filename: /var/lib/positions.yaml

clients:
  - url: http://{{ hostvars['loghost'].ip }}:3100/loki/api/v1/push

scrape_configs:
  - job_name: processors
    pipeline_stages:
      - drop:
          expression: '(?i)debug|trace'

    static_configs:
      - targets:
          - localhost
        labels:
          job: processors
          __path__: /var/log/pods/**/*proseo*/**/*.log